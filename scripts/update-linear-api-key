#!/usr/bin/env python3
from __future__ import annotations

import argparse
import os
import sys
from pathlib import Path


DEFAULT_ENV_FILES = [
    Path("/Users/daniel/code/leftoff/local.env"),
    Path("/Users/daniel/code/mealbuddy/local.env"),
    Path("/Users/daniel/code/ms.minutes/local.env"),
    Path("/Users/daniel/code/symphony/local.env"),
]


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        description="Update LINEAR_API_KEY across managed repo local.env files."
    )
    parser.add_argument(
        "value",
        nargs="?",
        help="New LINEAR_API_KEY value. Omit and pass --stdin to read from stdin.",
    )
    parser.add_argument(
        "--stdin",
        action="store_true",
        help="Read the new LINEAR_API_KEY value from stdin.",
    )
    parser.add_argument(
        "--dry-run",
        action="store_true",
        help="Print the files that would be updated without writing changes.",
    )
    return parser


def read_value(args: argparse.Namespace) -> str:
    if args.stdin:
        if args.value is not None:
            raise SystemExit("Pass either a positional value or --stdin, not both.")
        value = sys.stdin.read().strip()
    else:
        if args.value is None:
            raise SystemExit("Missing LINEAR_API_KEY value. Pass it as an argument or use --stdin.")
        value = args.value.strip()

    if value == "":
        raise SystemExit("LINEAR_API_KEY value must not be empty.")

    return value


def update_env_file(path: Path, new_value: str, dry_run: bool) -> bool:
    if not path.is_file():
        raise SystemExit(f"Env file not found: {path}")

    original = path.read_text(encoding="utf-8")
    lines = original.splitlines(keepends=True)
    updated = False
    new_lines: list[str] = []

    for line in lines:
        stripped = line.lstrip()
        if stripped.startswith("LINEAR_API_KEY="):
            newline = "\n" if line.endswith("\n") else ""
            prefix = line[: len(line) - len(stripped)]
            new_lines.append(f'{prefix}LINEAR_API_KEY="{new_value}"{newline}')
            updated = True
        else:
            new_lines.append(line)

    if not updated:
        raise SystemExit(f"LINEAR_API_KEY entry not found in {path}")

    new_content = "".join(new_lines)
    changed = new_content != original

    if changed and not dry_run:
        path.write_text(new_content, encoding="utf-8")

    return changed


def main() -> int:
    parser = build_parser()
    args = parser.parse_args()
    value = read_value(args)

    changed_paths: list[Path] = []
    unchanged_paths: list[Path] = []

    for path in DEFAULT_ENV_FILES:
        changed = update_env_file(path, value, args.dry_run)
        if changed:
            changed_paths.append(path)
        else:
            unchanged_paths.append(path)

    mode = "Would update" if args.dry_run else "Updated"
    for path in changed_paths:
        print(f"{mode}: {path}")

    for path in unchanged_paths:
        print(f"Already current: {path}")

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
